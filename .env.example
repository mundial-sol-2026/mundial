# ========================================
# 🔒 VARIABLES DE ENTORNO - SEGURIDAD CRÍTICA
# ========================================
# NUNCA subas archivo .env real al repositorio
# Configurar SOLO desde panel de Vercel como Encrypted Environment Variables

# ========================================
# Base de Datos: Vercel Postgres (Gratuita)
# ========================================
POSTGRES_URL=postgresql://user:password@host/database
POSTGRES_URL_NON_POOLING=postgresql://user:password@host/database

# ========================================
# Blockchain: Solana (RPC Proxy - SIN EXPONER API KEY DIRECTA)
# Usa este endpoint en el frontend, no directamente la clave
# ========================================
SOLANA_RPC_URL=http://localhost:3000/api/rpc

# ========================================
# Wallet de Distribución de Premios (HOT WALLET - SOLO SERVIDOR)
# ⚠️ CRÍTICO: Solo en Vercel, NUNCA en .env local público
# Generada tras comprar tokens en pump.fun
# ========================================
DISTRIBUTOR_PRIVATE_KEY=your_distributor_keypair_bs58_encoded_secret_key

# ========================================
# Token de Premios: pump.fun MINT Address
# Se obtiene tras crear el token en pump.fun
# ========================================
REWARD_TOKEN_MINT=MintAddressDelTokenEnPumpFun

# ========================================
# RPC Provider Real (Detrás del proxy /api/rpc)
# Este SÍ contiene la API key, pero NUNCA sale a internet público
# ========================================
NEXT_PUBLIC_RPC_PROVIDER=https://mainnet.helius-rpc.com/?api-key=your-api-key-here
# O alternativa: NEXT_PUBLIC_RPC_PROVIDER=https://api.quicknode.com/solana/your-key

# ========================================
# Configuración Opcional: Admin Panel / Liquidación de Partidos
# ========================================
ADMIN_SECRET_KEY=your_super_secret_admin_key_for_settlement
SPORT_API_KEY=your_sport_api_key_if_using_external_oracle

# ========================================
# Entorno
# ========================================
NODE_ENV=production
